# Transport mode: sse (default) or stdio
MCP_TRANSPORT=sse

# Port for SSE transport (default: 8099)
MCP_PORT=8099

# Server metadata shown to LLM clients
MCP_NAME=mcp-workbench
MCP_VERSION=1.0.0

# File API for the Hugo editor modal
API_PORT=8110

# Dashboard (Hugo dev server with hot reload)
DASHBOARD_PORT=1313
DASHBOARD_SITE_DIR=./apps/hugo-book-site

# Standalone Hugo Book app
HUGO_BOOK_PORT=1314

# File browser for editing markdown/yaml workspace files
FILEBROWSER_PORT=8080
